generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String?  @unique
  email     String?  @unique
  password  String
  role      String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String   @unique
  phone             String?
  rollNumber        String   @unique
  gender            String?
  department        String?
  checkInDate       String?
  roomNumber        String?
  currentSemester   String?
  residenceExpiry   String?
  selectedRoom      String?
  roomPrice         Float?
  residencyAccount  String?
  maintenanceCharge Float?
  securityDeposit   Float?
  messFee           Float?
  totalPayment      Float?
  paidAmount        Float?
  paymentStatus     String   @default("unpaid")
  lastPaymentDate   String?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messEnrollments MessEnrollment[]
  rebateRequests  RebateRequest[]
}

model Guest {
  id            String   @id @default(cuid())
  fullName      String
  phone         String
  aadhaarNumber String
  feePaid       Boolean  @default(false)
  feeAmount     Float?
  receiptNumber String?
  status        String   @default("otp_verified")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Otp {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
}

model MessEnrollment {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  studentName    String?
  rollNumber     String?
  couponNumber   String   @unique
  enrollmentDate String?
  mealType       String?
  status         String   @default("enrolled")
  servedAt       String?
  servedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MessNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  priority  String   @default("medium")
  isRead    Boolean  @default(false)
  expiresAt String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RebateRequest {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  studentName String?
  rollNumber  String?
  days        Int?
  status      String    @default("pending")
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Settings {
  id             String   @id @default(cuid())
  hostel         Json?
  rooms          Json?
  meals          Json?
  dietaryOptions Json?
  system         Json?
  guestFee       Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String   @unique
  floor      Int
  type       String
  capacity   Int
  price      Float
  status     String   @default("active")
  amenities  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  priority  String   @default("normal")
  postedBy  String   @default("Office Admin")
  isPinned  Boolean  @default(false)
  expiresAt String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceRequest {
  id           String    @id @default(cuid())
  ticketNumber String    @unique
  studentName  String
  rollNumber   String
  roomNumber   String
  category     String
  title        String
  description  String
  priority     String    @default("medium")
  status       String    @default("open")
  raisedAt     DateTime  @default(now())
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SupplierBill {
  id           String   @id @default(cuid())
  billNumber   String   @unique
  supplierName String
  category     String
  amount       Float
  billDate     String
  description  String
  photoData    String?
  registeredAt DateTime @default(now())
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StudentNotification {
  id        String   @id @default(cuid())
  studentId String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditRecord {
  id                String   @id @default(cuid())
  month             Int
  year              Int
  publishedAt       DateTime @default(now())
  daysInMonth       Int
  totalSupplierBill Float
  totalBillableDays Float
  perDayRate        Float
  studentCount      Int
  rebatedCount      Int
  totalStudentBill  Float
  rows              Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([month, year])
}
