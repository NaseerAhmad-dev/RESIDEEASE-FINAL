generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hostel {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  code       String    @unique
  hostelType String    @default("mixed")
  isActive   Boolean   @default(true)
  isReadOnly Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  location      HostelLocation?
  owners        HostelOwner[]
  settings      HostelSettings?
  subscriptions HostelSubscription[]
  payments      HostelPayment[]
  auditLogs     HostelAuditLog[]
  users         User[]
}

model HostelLocation {
  id           String  @id @default(cuid())
  hostelId     String  @unique
  hostel       Hostel  @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String  @default("India")
  latitude     Float?
  longitude    Float?
}

model HostelOwner {
  id        String   @id @default(cuid())
  hostelId  String
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  altPhone  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HostelSettings {
  id               String   @id @default(cuid())
  hostelId         String   @unique
  hostel           Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  totalSeats       Int?
  totalRooms       Int?
  hasMess          Boolean  @default(false)
  messType         String?
  noticePeriodDays Int      @default(30)
  logoUrl          String?
  website          String?
  description      String?
  timezone         String   @default("Asia/Kolkata")
  featureOverrides Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HostelSubscription {
  id           String    @id @default(cuid())
  hostelId     String
  hostel       Hostel    @relation(fields: [hostelId], references: [id], onDelete: Restrict)
  planId       String?
  planName     String
  status       String    @default("active")
  billingCycle String?
  seatLimit    Int?
  staffLimit   Int?
  startsAt     DateTime
  endsAt       DateTime?
  trialEndsAt  DateTime?
  graceEndsAt  DateTime?
  isCurrent    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  payments HostelPayment[]
}

model HostelPayment {
  id             String              @id @default(cuid())
  hostelId       String
  hostel         Hostel              @relation(fields: [hostelId], references: [id], onDelete: Restrict)
  subscriptionId String?
  subscription   HostelSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount         Float
  currency       String              @default("INR")
  status         String              @default("pending")
  paymentMethod  String?
  paidAt         DateTime?
  invoiceUrl     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model HostelAuditLog {
  id        String   @id @default(cuid())
  hostelId  String
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  actorId   String?
  actorRole String?
  action    String
  payload   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id        String   @id @default(cuid())
  username  String?  @unique
  email     String?  @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  hostelId  String?
  hostel    Hostel?  @relation(fields: [hostelId], references: [id])
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String   @unique
  phone             String?
  rollNumber        String   @unique
  gender            String?
  department        String?
  checkInDate       String?
  roomNumber        String?
  currentSemester   String?
  residenceExpiry   String?
  selectedRoom      String?
  roomPrice         Float?
  residencyAccount  String?
  maintenanceCharge Float?
  securityDeposit   Float?
  messFee           Float?
  totalPayment      Float?
  paidAmount        Float?
  paymentStatus     String   @default("unpaid")
  lastPaymentDate   String?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messEnrollments MessEnrollment[]
  rebateRequests  RebateRequest[]
}

model Guest {
  id            String   @id @default(cuid())
  fullName      String
  phone         String
  aadhaarNumber String
  feePaid       Boolean  @default(false)
  feeAmount     Float?
  receiptNumber String?
  status        String   @default("otp_verified")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Employee {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  phone      String?
  jobTitle   String
  department String?
  salary     Float?
  joinDate   String
  status     String   @default("active")
  address    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Otp {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
}

model MessEnrollment {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  studentName    String?
  rollNumber     String?
  couponNumber   String   @unique
  enrollmentDate String?
  mealType       String?
  status         String   @default("enrolled")
  servedAt       String?
  servedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MessNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  priority  String   @default("medium")
  isRead    Boolean  @default(false)
  expiresAt String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RebateRequest {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  studentName String?
  rollNumber  String?
  days        Int?
  status      String    @default("pending")
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Settings {
  id             String   @id @default(cuid())
  hostel         Json?
  rooms          Json?
  meals          Json?
  dietaryOptions Json?
  system         Json?
  guestFee       Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String   @unique
  floor      Int
  type       String
  capacity   Int
  price      Float
  status     String   @default("active")
  amenities  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  priority  String   @default("normal")
  postedBy  String   @default("Office Admin")
  isPinned  Boolean  @default(false)
  expiresAt String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceRequest {
  id           String    @id @default(cuid())
  ticketNumber String    @unique
  studentName  String
  rollNumber   String
  roomNumber   String
  category     String
  title        String
  description  String
  priority     String    @default("medium")
  status       String    @default("open")
  raisedAt     DateTime  @default(now())
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SupplierBill {
  id           String   @id @default(cuid())
  billNumber   String   @unique
  supplierName String
  category     String
  amount       Float
  billDate     String
  description  String
  photoData    String?
  registeredAt DateTime @default(now())
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StudentNotification {
  id        String   @id @default(cuid())
  studentId String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditRecord {
  id                String   @id @default(cuid())
  month             Int
  year              Int
  publishedAt       DateTime @default(now())
  daysInMonth       Int
  totalSupplierBill Float
  totalBillableDays Float
  perDayRate        Float
  studentCount      Int
  rebatedCount      Int
  totalStudentBill  Float
  rows              Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([month, year])
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   @default("info")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
